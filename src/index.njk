---
layout: base.njk
title: Home
---
<section class="hero">
  <h1>Welcome to Kimi's English Learning!</h1>
  <p>Fun English stories with vocabulary, grammar, and quizzes for young learners.</p>
</section>

<section class="tag-cloud">
  <h2>Explore by Topic</h2>
  <div class="tag-pills">
    {% for tag in collections.tagList %}
    <a href="/tags/{{ tag | slugify }}/" class="tag-pill">{{ tag }}</a>
    {% endfor %}
  </div>
</section>

<section class="article-grid-section">
  <h2>All Stories</h2>
  <div class="article-grid">
    {% for article in collections.articles %}
    <a href="{{ article.url }}" class="article-card">
      <div class="card-level level-{{ article.data.level | lower | replace(' ', '-') }}">{{ article.data.level }}</div>
      <h3>{{ article.data.title }}</h3>
      <p class="card-values">{{ article.data.characterValues }}</p>
      <div class="card-tags">
        {% for tag in article.data.tags %}
          {% if tag != "article" %}
          <span class="card-tag">{{ tag }}</span>
          {% endif %}
        {% endfor %}
      </div>
    </a>
    {% endfor %}
  </div>
</section>
